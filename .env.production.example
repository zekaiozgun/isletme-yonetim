# Bu dosyayi VM'de .env.production olarak kopyalayip gercek degerlerle
# doldurun. .env.production ASLA git'e eklenmez (.gitignore'da).
#
#   cp .env.production.example .env.production

# Guclu, rastgele bir sifre uretin, orn: openssl rand -base64 24
POSTGRES_PASSWORD=change_this_to_a_strong_random_password

# Sitenizin gorunecegi domain (sadece hostname, https:// veya / olmadan).
# Henuz gercek bir domain'iniz yoksa, VM'in statik IP'siyle calisan
# ucretsiz bir sslip.io adresi kullanabilirsiniz, orn: 34-123-45-67.sslip.io
DOMAIN=example.com
